/**
 * Sequelize CLI Configuration File
 * This file tells the Sequelize CLI where to find the config, models, and migrations 
 * because we are using a custom folder structure inside the 'src' directory.
 */
const path = require('path');

module.exports = {
  'config': path.resolve('src', 'config', 'config.cjs'),
  'models-path': path.resolve('src', 'models'),
  'migrations-path': path.resolve('src', 'migrations'),
  'seeders-path': path.resolve('src', 'seeders')
};